<Styles 
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Styles.Resources>
    <ResourceDictionary>
      <Style x:Key="GlassCardStyle" Selector="Border.GlassCard">
        <Setter Property="Background" Value="#08FFFFFF" /> 
        <Setter Property="BorderBrush" Value="#14FFFFFF" /> 
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/> 
      </Style>

      <Style x:Key="ScreenTitleStyle" Selector="TextBlock.ScreenTitle">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource Sky400Brush}"/>
      </Style>

      <Style x:Key="SectionTitleStyle" Selector="TextBlock.SectionTitle">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Slate100Brush}"/>
      </Style>

      <Style x:Key="CardTitleStyle" Selector="TextBlock.CardTitle">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
      </Style>

      <Style x:Key="CardSubtitleStyle" Selector="TextBlock.CardSubtitle">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource Slate300Brush}"/>
      </Style>
      
      <Style x:Key="SmallMutedTextStyle" Selector="TextBlock.SmallMutedText">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource Slate400Brush}"/>
      </Style>
      
      <Style x:Key="LinkTextStyle" Selector="TextBlock.LinkText">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource Sky400Brush}"/>
        <Setter Property="Cursor" Value="Hand"/>
      </Style>
      
      <Style x:Key="CategoryButtonIconStyle" Selector="TextBlock.CategoryButtonIcon">
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" /> 
        <Setter Property="FontSize" Value="28" />
        <Setter Property="Margin" Value="0,0,0,8" />
      </Style>
      
      <Style x:Key="CategoryButtonTextStyle" Selector="TextBlock.CategoryButtonText">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Slate100Brush}"/>
      </Style>
      
      <Style x:Key="CategoryButtonSubtextStyle" Selector="TextBlock.CategoryButtonSubtext">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource Slate400Brush}"/>
      </Style>

      <Style x:Key="IconButton" Selector="Button.IconButton">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource Slate300Brush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
      </Style>

      <Style x:Key="PlayButtonStyle" Selector="Button.PlayButton">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource Slate300Brush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Cursor" Value="Hand"/>
      </Style>

      <Style x:Key="CategoryButtonStyle" Selector="Button.CategoryButton">
        <!-- <Setter Property="Classes" Value="GlassCard"/>  -->
        <Setter Property="Padding" Value="16"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
      </Style>
    </ResourceDictionary>
  </Styles.Resources>
</Styles>
