<Styles 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <ResourceDictionary>
            <Style x:Key="HamburgerButtonStyle" Selector="Button.HamburgerButton">
                <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource Slate300Brush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="ContentTemplate">
                    <DataTemplate>
                        <StackPanel Spacing="4">
                            <Rectangle Fill="{Binding $parent[Button].Foreground}" Height="2" Width="20"/>
                            <Rectangle Fill="{Binding $parent[Button].Foreground}" Height="2" Width="20"/>
                            <Rectangle Fill="{Binding $parent[Button].Foreground}" Height="2" Width="20"/>
                        </StackPanel>
                    </DataTemplate>
                </Setter>
            </Style>

            <Style x:Key="CarouselTitleStyle" Selector="TextBlock.CarouselTitle">
                <Setter Property="FontSize" Value="28"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="Margin" Value="0,0,0,5"/>
            </Style>

            <Style x:Key="CarouselSubtitleStyle" Selector="TextBlock.CarouselSubtitle">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Foreground" Value="{StaticResource Slate300Brush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="ShortcutButtonStyle" Selector="Button.ShortcutButton">
                <Setter Property="Background" Value="{StaticResource Slate700Brush}"/>
                <Setter Property="Foreground" Value="{StaticResource Slate100Brush}"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{StaticResource Slate600Brush}"/>
            </Style>

            <Style x:Key="ShortcutButtonTextStyle" Selector="TextBlock.ShortcutButtonText">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,8,0,0"/>
            </Style>

            <Style x:Key="ShortcutButtonIconButtonStyle" Selector="TextBlock.ShortcutButtonIcon">
                <Setter Property="FontSize" Value="28"/> 
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/> 
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{StaticResource Sky400Brush}"/>
            </Style>

            <Style x:Key="H1Style" Selector="TextBlock.H1">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource Sky400Brush}"/>
            </Style>

            <Style x:Key="ExerciseTitleStyle" Selector="TextBlock.ExerciseTitle">
                <Setter Property="FontSize" Value="40"/> <Setter Property="FontWeight" Value="ExtraBold"/>
                <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="TextAlignment" Value="Center"/>
            </Style>

            <Style x:Key="RepCountStyle" Selector="TextBlock.RepCount">
                <Setter Property="FontSize" Value="28"/> <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource Sky400Brush}"/>
                <Setter Property="TextAlignment" Value="Center"/>
            </Style>

            <Style x:Key="MutedTextStyle" Selector="TextBlock.MutedText">
                <Setter Property="Foreground" Value="{StaticResource Slate300Brush}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            
            <Style x:Key="SmallMutedTextStyle" Selector="TextBlock.SmallMutedText">
                <Setter Property="Foreground" Value="{StaticResource Slate400Brush}"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>
            
            <Style x:Key="FormCueTitleStyle" Selector="TextBlock.FormCueTitle">
                <Setter Property="Foreground" Value="{StaticResource Slate300Brush}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="TextAlignment" Value="Center"/>
            </Style>

            <Style x:Key="FormCueItemStyle" Selector="TextBlock.FormCueItem">
                <Setter Property="Foreground" Value="{StaticResource Slate400Brush}"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <Style x:Key="PrimaryButtonStyle" Selector="Button.Primary">
                <Setter Property="Background" Value="{StaticResource Sky500Brush}"/>
                <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="16,14"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <Style x:Key="SecondaryButtonStyle" Selector="Button.Secondary">
                <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource Slate300Brush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Slate600Brush}"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
        </ResourceDictionary>
    </Styles.Resources>
</Styles>
