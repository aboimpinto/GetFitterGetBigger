<UserControl 
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
  x:Class="GetFitterGetBigger.Views.RepBaseExerciseView">
  
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,10">
    <StackPanel Spacing="20" HorizontalAlignment="Stretch">
        
      <StackPanel Spacing="4" Margin="0,10,0,0">
        <TextBlock Classes="ExerciseTitle" Text="{Binding ExerciseInfo}" HorizontalAlignment="Center" />
        <TextBlock Classes="RepCount" Text="10 Reps" HorizontalAlignment="Center" />
        <TextBlock Classes="MutedText" Text="Exercise 1 of 3 this round" TextAlignment="Center" FontWeight="Medium" HorizontalAlignment="Center"/>
      </StackPanel>

      <Border 
        MinHeight="180" 
        Background="#AA2A303C" 
        CornerRadius="12"
        BorderBrush="#55FFFFFF" 
        BorderThickness="1"> 
        <Image 
          Source="{Binding ImageSource}"
          Stretch="UniformToFill"
          HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Border>
      
      <StackPanel Spacing="6" HorizontalAlignment="Center">
        <TextBlock Text="Key Form Cues:" Classes="FormCueTitle"/>
        <StackPanel 
          Spacing="2" 
          HorizontalAlignment="Center"> 
          <TextBlock Text="• Keep chest up" Classes="FormCueItem" HorizontalAlignment="Left"/>
          <TextBlock Text="• Weight in heels" Classes="FormCueItem" HorizontalAlignment="Left"/>
          <TextBlock Text="• Go below parallel" Classes="FormCueItem" HorizontalAlignment="Left"/>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>


  <!-- <Grid RowDefinitions="50 50 50 50 50 50 *">
    <TextBlock 
      Grid.Row="1" 
      Text="{Binding WorkoutName}"
      VerticalAlignment="Center"
      HorizontalAlignment="Center"
      FontSize="22"
      FontWeight="Bold" />

    <TextBlock 
      Grid.Row="2" 
      Text="{Binding RoundInfo}"
      VerticalAlignment="Center"
      HorizontalAlignment="Center"
      FontSize="18"
      FontWeight="Bold" />

    <TextBlock 
      Grid.Row="3" 
      Text="{Binding SetInfo}"
      VerticalAlignment="Center"
      HorizontalAlignment="Center"
      FontSize="18"
      FontWeight="Bold" />

    <TextBlock 
      Grid.Row="4" 
      Text="{Binding ExerciseInfo}"
      VerticalAlignment="Center"
      HorizontalAlignment="Center"
      FontSize="18"
      FontWeight="Bold" />

    <TextBlock 
      Grid.Row="5" 
      Text="{Binding Reps}"
      VerticalAlignment="Center"
      HorizontalAlignment="Center"
      FontSize="18"
      FontWeight="Bold" />
  </Grid> -->

</UserControl>
