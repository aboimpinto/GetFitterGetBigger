<UserControl 
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:controls="using:Olimpo.Controls"
  mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
  x:Class="GetFitterGetBigger.Views.WorkoutsView">
  
  <UserControl.Styles>
    <Style Selector="Border.GlassCard">
      <Setter Property="Background" Value="#08FFFFFF" /> 
      <Setter Property="BorderBrush" Value="#14FFFFFF" /> 
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="16"/> 
    </Style>

    <Style Selector="TextBlock.ScreenTitle">
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="{StaticResource Sky400Brush}"/>
    </Style>

    <Style Selector="TextBlock.SectionTitle">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Slate100Brush}"/>
      </Style>

      <Style Selector="TextBlock.CardTitle">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
      </Style>

      <Style Selector="TextBlock.CardSubtitle">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource Slate300Brush}"/>
      </Style>
      
      <Style Selector="TextBlock.SmallMutedText">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource Slate400Brush}"/>
      </Style>
      
      <Style Selector="TextBlock.LinkText">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource Sky400Brush}"/>
        <Setter Property="Cursor" Value="Hand"/>
      </Style>
      
      <Style Selector="TextBlock.CategoryButtonIcon">
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" /> 
        <Setter Property="FontSize" Value="28" />
        <Setter Property="Margin" Value="0,0,0,8" />
      </Style>
      
      <Style Selector="TextBlock.CategoryButtonText">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Slate100Brush}"/>
      </Style>
      
      <Style Selector="TextBlock.CategoryButtonSubtext">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource Slate400Brush}"/>
      </Style>

      <Style Selector="Button.IconButton">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource Slate300Brush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
      </Style>

      <Style Selector="Button.PlayButton">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource Slate300Brush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Cursor" Value="Hand"/>
      </Style>

      <Style Selector="Button.CategoryButton">
        <!-- <Setter Property="Classes" Value="GlassCard"/>  -->
        <Setter Property="Padding" Value="16"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
      </Style>
  </UserControl.Styles>

  <Panel Background="{StaticResource Slate900Brush}">
    <Border 
      MaxWidth="390" 
      Height="800"
      Background="{StaticResource Slate800Brush}"
      CornerRadius="0" BorderThickness="0"
      HorizontalAlignment="Center" 
      VerticalAlignment="Center"
      ClipToBounds="True">
            
      <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#D91E293B" Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="{StaticResource Slate700Brush}">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <controls:IconButton
              Data="{StaticResource ArrowLeftCicle}"
              Command="{Binding BackMenuCommand}"
              ToolTip.Tip="Go Back"
              Foreground="{StaticResource Slate300Brush}"
              Background="{StaticResource TransparentBrush}" />

            <TextBlock 
              Grid.Column="1" 
              Text="Workouts" 
              Classes="ScreenTitle" 
              VerticalAlignment="Center" 
              HorizontalAlignment="Left" 
              Margin="12 0 0 0"/>
          </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="28" Margin="20"> 
            <StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Workout of the Day" Classes="SectionTitle"/>
                <TextBlock Grid.Column="1" Text="Changes Daily" Classes="SmallMutedText" VerticalAlignment="Center" />
              </Grid>

              <Border Classes="GlassCard">
                <Border.Resources>
                  <Style x:Key="WotDDetailsStyle" Selector="TextBlock.WotDDetails">
                    <Setter Property="Margin" Value="0 12 0 0"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Foreground" Value="{StaticResource Slate400Brush}"/>
                  </Style>
                </Border.Resources>

                <Grid ColumnDefinitions="Auto * Auto" RowDefinitions="Auto Auto Auto" VerticalAlignment="Center">
                  <Border 
                    Grid.Row="0" 
                    Grid.RowSpan="2" 
                    Background="#330EA5E9" 
                    CornerRadius="8" 
                    Width="48" 
                    Height="48" 
                    Margin="0 0 16 0"
                    VerticalAlignment="Center">

                    <controls:Icon 
                      Data="{StaticResource Flash}"
                      Foreground="{StaticResource Sky400Brush}"
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center" />
                  </Border>

                  <TextBlock 
                    Grid.Row="0"
                    Grid.Column="1" 
                    Text="{Binding WorkoutOfTheDaySummary.Title}" 
                    Classes="CardTitle" />

                  <TextBlock 
                    Grid.Column="1" 
                    Grid.Row="1" 
                    Text="{Binding WorkoutOfTheDaySummary.SubTitle}" 
                    TextWrapping="Wrap"
                    Classes="CardSubtitle" 
                    TextTrimming="CharacterEllipsis" />
                  
                  <controls:IconButton
                    Grid.Column="2" 
                    Grid.RowSpan="2"
                    Command="{Binding WorkoutOfTheDayCommand}"
                    Data="{StaticResource Play}"
                    ToolTip.Tip="Start workout"
                    Foreground="{StaticResource Sky400Brush}"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right" />
                  
                  <TextBlock 
                    Grid.Row="2" 
                    Grid.Column="0"
                    Grid.ColumnSpan="3" 
                    Text="{Binding WorkoutOfTheDaySummary.Description}" 
                    TextWrapping="Wrap"
                    VerticalAlignment="Bottom"
                    Classes="SmallMutedText WotDDetails" 
                    Margin="0 12 0 0"/>
                </Grid>
              </Border>
            </StackPanel>

            <StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock 
                  Text="Next Planned Workout" 
                  Classes="SectionTitle"/>
                <TextBlock 
                  Grid.Column="1" 
                  Text="View Plan" 
                  Classes="LinkText" 
                  ToolTip.Tip="View your full training plan"
                  VerticalAlignment="Center" />
              </Grid>

              <Border Classes="GlassCard">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="Auto * Auto" VerticalAlignment="Top">
                    <Border Grid.RowSpan="2" Background="#3322C55E" CornerRadius="8" Width="48" Height="48" Margin="0 0 16 0" VerticalAlignment="Top">
                      <controls:Icon 
                        Data="{StaticResource PlannedWorkout}"
                        Foreground="{StaticResource Green400Brush}"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center" />
                    </Border>
                    
                    <StackPanel Grid.Column="1" Spacing="2">
                      <Border Background="{StaticResource Green500Brush}" CornerRadius="10" Padding="6,2" HorizontalAlignment="Left">
                        <TextBlock 
                          Text="{Binding WorkoutActivePlan}" 
                          FontSize="10" 
                          FontWeight="SemiBold" 
                          Foreground="{StaticResource WhiteBrush}"/>
                      </Border>

                      <TextBlock 
                        Classes="CardTitle" 
                        Text="{Binding ActivePlanWorkout.Title}" />
                      <TextBlock 
                        Classes="CardSubtitle"
                        Text="{Binding ActivePlanWorkout.SubTitle}" 
                        TextWrapping="Wrap"/>
                    </StackPanel>

                    <controls:IconButton
                      Grid.Column="2" 
                      Grid.RowSpan="2"
                      Data="{StaticResource Play}"
                      ToolTip.Tip="Start Legs I workout"
                      Foreground="{StaticResource Green400Brush}"
                      VerticalAlignment="Top"
                      HorizontalAlignment="Right" />
                  </Grid>

                  <Rectangle Height="1" Fill="{StaticResource Slate700Brush}" Margin="0,4,0,4"/>

                  <TextBlock Text="{Binding ActivePlanWorkout.Description}" Classes="SmallMutedText"/>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Choose Your Workout" Classes="SectionTitle"/>
                <TextBlock Grid.Column="1" Text="See All" Classes="LinkText" ToolTip.Tip="Browse all available workouts"/>
              </Grid>

              <UniformGrid Columns="3" Rows="2"> <!-- Gap="16" -->

                <Button 
                  Classes="ShortcutButton" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Center"
                  Width="94"
                  Height="92">
                  <Border Background="#00000000">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                      <controls:IconButton
                        Data="{StaticResource HIIT}"
                        Foreground="{StaticResource Orange400Brush}"
                        HorizontalAlignment="Center" />
                      <TextBlock 
                        Text="HIIT" 
                        Classes="CategoryButtonText"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Center" />
                      <TextBlock 
                        Text="High Intensity" 
                        Classes="CategoryButtonSubtext"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Center" />
                    </StackPanel>
                  </Border>
                </Button>

                <Button 
                  Classes="ShortcutButton" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Center"
                  Width="94"
                  Height="92">
                  <Border Background="#00000000">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                      <controls:IconButton
                        Data="{StaticResource ARMS}"
                        Foreground="{StaticResource Red400Brush}"
                        HorizontalAlignment="Center" />
                      <TextBlock 
                        Text="Arms" 
                        Classes="CategoryButtonText"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Center" />
                      <TextBlock 
                        Text="Biceps, Triceps" 
                        Classes="CategoryButtonSubtext"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Center" />
                    </StackPanel>
                  </Border>
                </Button>

                <Button 
                  Classes="ShortcutButton" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Center"
                  Width="94"
                  Height="92">
                  <Border Background="#00000000">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                      <controls:IconButton
                        Data="{StaticResource LEGS}"
                        Foreground="{StaticResource Yellow400Brush}"
                        HorizontalAlignment="Center" />
                      <TextBlock 
                        Text="Legs" 
                        Classes="CategoryButtonText"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Center" />
                      <TextBlock 
                        Text="Quads, Glutes" 
                        Classes="CategoryButtonSubtext"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Center" />
                    </StackPanel>
                  </Border>
                </Button>

                <Button 
                  Classes="ShortcutButton" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Center"
                  Width="94"
                  Height="92">
                  <Border Background="#00000000">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                      <controls:IconButton
                        Data="{StaticResource ABS}"
                        Foreground="{StaticResource Teal400Brush}"
                        HorizontalAlignment="Center" />
                      <TextBlock 
                        Text="Abs &amp; Core" 
                        Classes="CategoryButtonText"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Center" />
                      <TextBlock 
                        Text="Core Strength" 
                        Classes="CategoryButtonSubtext"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Center" />
                    </StackPanel>
                  </Border>
                </Button>

                <Button 
                  Classes="ShortcutButton" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Center"
                  Width="94"
                  Height="92">
                  <Border Background="#00000000">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                      <controls:IconButton
                        Data="{StaticResource SHOULDERS}"
                        Foreground="{StaticResource Indigo400Brush}"
                        HorizontalAlignment="Center" />
                      <TextBlock 
                        Text="Shoulders" 
                        Classes="CategoryButtonText"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Center" />
                      <TextBlock 
                        Text="Deltoids" 
                        Classes="CategoryButtonSubtext"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Center" />
                    </StackPanel>
                  </Border>
                </Button>

                <Button 
                  Classes="ShortcutButton" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Center"
                  Width="94"
                  Height="92">
                  <Border Background="#00000000">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                      <controls:IconButton
                        Data="{StaticResource BACK}"
                        Foreground="{StaticResource Indigo400Brush}"
                        HorizontalAlignment="Center" />
                      <TextBlock 
                        Text="Back" 
                        Classes="CategoryButtonText"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Center" />
                      <TextBlock 
                        Text="Lats, Traps" 
                        Classes="CategoryButtonSubtext"
                        TextWrapping="Wrap"
                        HorizontalAlignment="Center" />
                    </StackPanel>
                  </Border>
                </Button>
                

                <!-- 
                <Button Classes="CategoryButton">
                  <StackPanel>
                    <TextBlock Classes="CategoryButtonIcon" Text="&#xE77B;" Foreground="{StaticResource Pink400Brush}"/> <TextBlock Classes="CategoryButtonText" Text="Back"/>
                    <TextBlock Classes="CategoryButtonSubtext" Text="Lats, Traps"/>
                  </StackPanel>
                </Button> -->
              </UniformGrid>

              <TextBlock Text="More categories unlocked as you progress!" Classes="SmallMutedText" TextAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <Panel Height="32"/> 
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>
  </Panel>


  <!-- <Grid RowDefinitions="Auto 50 Auto 50 Auto 100 Auto">

    <Grid Grid.Row="0" ColumnDefinitions="Auto *">
      <controls:IconButton
        Grid.Row="0"
        Data="{StaticResource HamburgerMenu}"
        Command="{Binding ToggleHamburgerMenuCommand}"
        VerticalAlignment="Center"
        HorizontalAlignment="Center" />

      <TextBlock 
        Grid.Column="1" 
        Text="Workouts"
        VerticalAlignment="Center"
        HorizontalAlignment="Left"
        FontSize="28"
        FontWeight="Bold"
        Margin="10 0 0 0" 
        Foreground="#047872" />
    </Grid>

    <Grid Grid.Row="2" RowDefinitions="35 10 30 50 35 10 30 50 35 10 *" ColumnDefinitions="320 35">
      
      <TextBlock 
        Grid.Row="0" 
        Grid.Column="0"
        Text="Workout of the Day"
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        FontSize="28"
        FontWeight="Bold" />

      <TextBlock 
        Grid.Row="2" 
        Grid.Column="0"
        Text="{Binding WorkoutOfTheDayCaption}"
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        FontSize="20"/>

      <controls:IconButton
        Grid.Row="0"
        Grid.RowSpan="3"
        Grid.Column="1"
        Foreground="#047872"
        Data="{StaticResource NavigateForward}"
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        Command="{Binding WorkoutOfTheDayCommand}" />
      
      
      <TextBlock 
        Grid.Row="4" 
        Grid.Column="0"
        Text="Planned Workout"
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        FontSize="28"
        FontWeight="Bold" />

      <StackPanel Grid.Row="6" Grid.Column="0" Orientation="Vertical">
        <TextBlock 
          Text="{Binding WorkoutActivePlan}"
          VerticalAlignment="Center"
          HorizontalAlignment="Center"
          FontSize="20" 
          Margin="0 0 10 0" />

        <TextBlock 
          Text="{Binding ActivePlanWorkoutName}"
          VerticalAlignment="Center"
          HorizontalAlignment="Center"
          FontSize="28" />
      </StackPanel>

      <controls:IconButton
        Grid.Row="4"
        Grid.RowSpan="3"
        Grid.Column="1"
        Foreground="#047872"
        Data="{StaticResource NavigateForward}"
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        Command="{Binding PlanedWorkoutCommand}" />

      <TextBlock 
        Grid.Row="8" 
        Grid.Column="0"
        Text="Choose Workout"
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        FontSize="28"
        FontWeight="Bold" />

      <WrapPanel Grid.Row="10" Grid.Column="0" Orientation="Horizontal">

        <Border Background="#047872" Width="60" Height="35" CornerRadius="8" Margin="10">
          <TextBlock 
            Text="HIIT" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center" 
            Foreground="White"
            FontSize="16"
            FontWeight="Bold" />
        </Border>

        <Border Background="#047872" Width="100" Height="35" CornerRadius="8" Margin="10">
          <TextBlock 
            Text="Shoulders" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center" 
            Foreground="White"
            FontSize="16"
            FontWeight="Bold" />
        </Border>

        <Border Background="#047872" Width="60" Height="35" CornerRadius="8" Margin="10">
          <TextBlock 
            Text="Legs" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center" 
            Foreground="White"
            FontSize="16"
            FontWeight="Bold" />
        </Border>

        <Border Background="#047872" Width="60" Height="35" CornerRadius="8" Margin="10">
          <TextBlock 
            Text="Arms" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center" 
            Foreground="White"
            FontSize="16"
            FontWeight="Bold" />
        </Border>

        <Border Background="#047872" Width="60" Height="35" CornerRadius="8" Margin="10">
          <TextBlock 
            Text="Abs" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center" 
            Foreground="White"
            FontSize="16"
            FontWeight="Bold" />
        </Border>

        <Border Background="#047872" Width="60" Height="35" CornerRadius="8" Margin="10">
          <TextBlock 
            Text="Back" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center" 
            Foreground="White"
            FontSize="16"
            FontWeight="Bold" />
        </Border>

      </WrapPanel>
    </Grid>
  </Grid> -->

</UserControl>
